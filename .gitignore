# =============================================================================
# .gitignore — files Git should NOT track and upload to GitHub
# =============================================================================

# Jekyll build output (regenerated by GitHub Pages on every push)
_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/

# Ruby/Bundler local state (only relevant if you ever install Jekyll locally)
vendor/
.bundle/
Gemfile.lock

# Editor / OS clutter
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# Python tooling for the import scripts
scripts/__pycache__/
scripts/*.pyc
scripts/.venv/
scripts/venv/

# Blogger XML exports — keep them local, don't commit (often huge + private)
*.xml
!_data/*.xml
.claude/
